# Bootstrap del curso (local; el script bootstrap-docs-curso.sh lo gestiona)
CURRICULUM=

# Supabase (se rellena en F3)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Envelope encryption KEK (se rellena en F7: openssl rand -hex 32)
AI_KEY_KEK=

# OpenAI: solo para el path de prueba del extractor en F6; en F7 se reemplaza por BYO key cifrada
OPENAI_API_KEY=

# Langfuse (se rellena en F7)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# Stripe (se rellena en F8)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# Inngest (se rellena en F6)
INNGEST_SIGNING_KEY=

# Sentry (se rellena en F10)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# PostHog (se rellena en F10)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
